{
    "name": "rouxtaccess/laravel-sync",
    "description": "Pull production databases, files and S3 buckets down to your local Laravel environment.",
    "keywords": [
        "rouxtaccess",
        "laravel",
        "sync",
        "database",
        "development"
    ],
    "homepage": "https://github.com/rouxtaccess/laravel-sync",
    "license": "MIT",
    "authors": [
        {
            "name": "John Roux",
            "email": "john.roux1@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "laravel/prompts": "^0.1.6 || ^0.2 || ^0.3",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rouxtaccess\\Sync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rouxtaccess\\Sync\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rouxtaccess\\Sync\\SyncServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
